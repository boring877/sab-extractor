{
  "name": "sab-extractor",
  "version": "0.3.2",
  "private": true,
  "description": "Silver and Blood game data extractor",
  "type": "module",
  "scripts": {
    "dev:renderer": "vite",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:tauri\"",
    "dev:tauri": "wait-on tcp:5173 && tauri dev",
    "build": "vite build",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "vite": "^6.3.0",
    "wait-on": "^8.0.3"
  }
}
